{
  "vault": {
    "path": "~/Documents/engram-vault"
  },
  "server": {
    "port": 7384,
    "https": false,
    "certFile": "/path/to/certs/localhost.pem",
    "keyFile": "/path/to/certs/localhost-key.pem"
  },
  "chroma": {
    "host": "http://localhost:8000",
    "collection": "engrams"
  },
  "wikilinks": {
    "threshold": 0.72,
    "maxLinks": 5
  },
  "embedding": {
    "overheadBuffer": 0.25,
    "vllm": {
      "host": "http://localhost:8001",
      "healthTimeout": 2000
    }
  },
  "watcher": {
    "enabled": true,
    "pdfChunkPages": 6
  },
  "captioning": {
    "provider": "ollama",
    "host": "http://localhost:11434/v1",
    "model": "engram-caption",
    "prompt": "Describe this image concisely for search and retrieval."
  }
}
