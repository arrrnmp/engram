{
  "vault": {
    "path": "~/Documents/engram-vault"
  },
  "server": {
    "port": 7384,
    "https": false,
    "certFile": "/path/to/certs/localhost.pem",
    "keyFile": "/path/to/certs/localhost-key.pem"
  },
  "chroma": {
    "host": "http://localhost:8000",
    "collection": "engrams"
  },
  "wikilinks": {
    "threshold": 0.72,
    "maxLinks": 5
  },
  "embedding": {
    "provider": "auto",
    "overheadBuffer": 0.25,
    "ollama": {
      "host": "http://localhost:11434"
    },
    "nvidia": {
      "host": "http://localhost:8001"
    },
    "openai": {
      "apiKey": "sk-...",
      "model": "text-embedding-3-small"
    }
  }
}
