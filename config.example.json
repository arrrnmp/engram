{
  "vault": {
    "path": "~/Documents/engram-vault"
  },
  "server": {
    "port": 7384,
    "https": false,
    "certFile": "/path/to/certs/localhost.pem",
    "keyFile": "/path/to/certs/localhost-key.pem"
  },
  "chroma": {
    "host": "http://localhost:8000",
    "collection": "engrams"
  },
  "wikilinks": {
    "threshold": 0.72,
    "maxLinks": 5
  },
  "embedding": {
    "overheadBuffer": 0.25,
    "vllm": {
      "host": "http://localhost:8001",
      "healthTimeout": 2000
    }
  },
  "watcher": {
    "enabled": true,
    "pdfChunkPages": 6
  },
  "captioning": {
    "provider": "auto",
    "host": "http://localhost:8002/v1",
    "model": "mlx-community/Qwen3.5-4B-MLX-4bit",
    "prompt": "Describe this image concisely for search and retrieval.",
    "maxTokens": 256,
    "temperature": 0.7,
    "topP": 0.8,
    "topK": 20,
    "minP": 0.0,
    "presencePenalty": 1.5,
    "repetitionPenalty": 1.0,
    "think": false,
    "extraBody": {}
  }
}
